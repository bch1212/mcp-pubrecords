# PubRecords MCP — environment variables

# Optional: bump cache TTL (seconds). Default 86400 (24h).
PUBRECORDS_CACHE_TTL=86400

# Optional: path to SQLite cache file. Default ./pubrecords_cache.db
PUBRECORDS_DB_PATH=./pubrecords_cache.db

# Optional: User-Agent string for SEC EDGAR (SEC requires identifying UA).
PUBRECORDS_SEC_USER_AGENT="PubRecords MCP contact@example.com"

# Optional: CourtListener token (anonymous works but rate limited).
COURTLISTENER_TOKEN=

# Optional: OpenCorporates API token (anonymous works but limited to 50/mo).
OPENCORPORATES_TOKEN=

# Server port (Railway sets this automatically).
PORT=8000
